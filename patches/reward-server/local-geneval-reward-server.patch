@@ -0,0 +1,135 @@
+"""MMCV compatibility exports for reward-server's MMDetection 2.x path.
+
+The reward-server GenEval code uses MMDetection 2.x, which expects several
+MMCV 1.x symbols at ``mmcv`` and ``mmcv.utils`` import locations. The current
+environment uses a locally built ``mmcv-full==1.7.2`` wheel, so this is mostly
+a no-op guard against missing legacy exports if the environment drifts.
+"""
+
+from __future__ import annotations
+
+import importlib
+
+import mmcv
+import mmcv.utils as mmcv_utils
+
+
+LEGACY_EXPORT_MODULES = (
+    "mmcv.utils.config",
+    "mmcv.utils.hub",
+    "mmcv.utils.logging",
+    "mmcv.utils.misc",
+    "mmcv.utils.parrots_wrapper",
+    "mmcv.utils.path",
+    "mmcv.utils.progressbar",
+    "mmcv.utils.registry",
+    "mmcv.utils.seed",
+    "mmcv.utils.timer",
+    "mmcv.utils.version_utils",
+)
+
+PRIVATE_COMPAT_EXPORTS = (
+    "_AdaptiveAvgPoolNd",
+    "_AdaptiveMaxPoolNd",
+    "_AvgPoolNd",
+    "_BatchNorm",
+    "_ConvNd",
+    "_ConvTransposeMixin",
+    "_InstanceNorm",
+    "_MaxPoolNd",
+)
+
+TOP_LEVEL_EXPORTS = (
+    "Config",
+    "ConfigDict",
+    "DictAction",
+    "ProgressBar",
+    "Registry",
+    "build_from_cfg",
+    "check_file_exist",
+    "digit_version",
+    "get_git_hash",
+    "get_logger",
+    "is_list_of",
+    "is_seq_of",
+    "jit",
+    "mkdir_or_exist",
+    "print_log",
+    "scandir",
+    "skip_no_elena",
+    "to_1tuple",
+    "to_2tuple",
+    "to_3tuple",
+    "to_4tuple",
+    "track_iter_progress",
+)
+
+OPTIONAL_DEVICE_FLAGS = (
+    "IS_IPU_AVAILABLE",
+    "IS_XPU_AVAILABLE",
+)
+
+
+def _copy_public_exports(module: object) -> None:
+    for name in dir(module):
+        if name.startswith("_") and name not in PRIVATE_COMPAT_EXPORTS:
+            continue
+        if hasattr(mmcv_utils, name):
+            continue
+        setattr(mmcv_utils, name, getattr(module, name))
+
+
+def ensure_mmcv_legacy_exports() -> None:
+    for module_name in LEGACY_EXPORT_MODULES:
+        module = importlib.import_module(module_name)
+        _copy_public_exports(module)
+
+    if not hasattr(mmcv_utils, "TORCH_VERSION"):
+        import torch
+
+        mmcv_utils.TORCH_VERSION = torch.__version__
+
+    for name in OPTIONAL_DEVICE_FLAGS:
+        if not hasattr(mmcv_utils, name):
+            setattr(mmcv_utils, name, False)
+
+    for name in TOP_LEVEL_EXPORTS:
+        if hasattr(mmcv_utils, name) and not hasattr(mmcv, name):
+            setattr(mmcv, name, getattr(mmcv_utils, name))
+
+    if not hasattr(mmcv, "TORCH_VERSION"):
+        mmcv.TORCH_VERSION = mmcv_utils.TORCH_VERSION
+
+    import mmcv.cnn as mmcv_cnn
+    import mmcv.cnn.bricks.registry as bricks_registry
+    import mmcv.cnn.bricks.transformer as bricks_transformer
+    import mmcv.cnn.utils.weight_init as weight_init
+
+    if not hasattr(mmcv_cnn, "MODELS"):
+        mmcv_cnn.MODELS = mmcv_utils.Registry("models")
+    for name in (
+        "ACTIVATION_LAYERS",
+        "ATTENTION",
+        "CONV_LAYERS",
+        "DROPOUT_LAYERS",
+        "FEEDFORWARD_NETWORK",
+        "NORM_LAYERS",
+        "PADDING_LAYERS",
+        "PLUGIN_LAYERS",
+        "POSITIONAL_ENCODING",
+        "TRANSFORMER_LAYER",
+        "TRANSFORMER_LAYER_SEQUENCE",
+        "UPSAMPLE_LAYERS",
+    ):
+        if hasattr(bricks_registry, name) and not hasattr(mmcv_cnn, name):
+            setattr(mmcv_cnn, name, getattr(bricks_registry, name))
+        if hasattr(bricks_registry, name) and not hasattr(bricks_transformer, name):
+            setattr(bricks_transformer, name, getattr(bricks_registry, name))
+    for name in dir(weight_init):
+        if not name.startswith("_") and not hasattr(mmcv_cnn, name):
+            setattr(mmcv_cnn, name, getattr(weight_init, name))
+
+    exported = set(getattr(mmcv_utils, "__all__", ()))
+    exported.update(name for name in TOP_LEVEL_EXPORTS if hasattr(mmcv_utils, name))
+    exported.add("TORCH_VERSION")
+    mmcv_utils.__all__ = sorted(exported)
