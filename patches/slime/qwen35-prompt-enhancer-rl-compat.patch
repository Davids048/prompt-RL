-    bridge = AutoBridge.from_pretrained(hf_model_path, trust_remote_code=True)
+    bridge = _load_bridge(hf_model_path)
     bridge.load_weights(model, hf_model_path, memory_efficient=True)
     print(f"Model loaded: {hf_model_path}")
 
