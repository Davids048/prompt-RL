@@ -1,4 +1,5 @@
 import gc
+import json
 import os
 import shutil
 
@@ -18,6 +19,38 @@ from slime.utils.logging_utils import configure_logger
 from slime.utils.memory_utils import print_memory
 
 
+def _load_bridge(hf_model_path):
+    """Load an mbridge bridge even when Transformers cannot parse new Qwen3.5 configs.
+
+    The local Transformers package may not recognize ``model_type=qwen3_5`` yet,
+    but Slime registers a Qwen3.5 bridge with mbridge. Reading ``config.json``
+    directly lets AutoBridge select that bridge from a lightweight config object.
+    """
+    try:
+        return AutoBridge.from_pretrained(hf_model_path, trust_remote_code=True)
+    except (KeyError, ValueError):
+        config_path = os.path.join(hf_model_path, "config.json")
+        with open(config_path) as f:
+            config_dict = json.load(f)
+
+        dtype_map = {"bfloat16": torch.bfloat16, "float16": torch.float16, "float32": torch.float32}
+
+        def fix_dtype(d):
+            for key in ("torch_dtype", "dtype"):
+                if key in d:
+                    d[key] = dtype_map.get(d[key], d[key])
+
+        fix_dtype(config_dict)
+        hf_config = type("HFConfig", (), config_dict)()
+        if "text_config" in config_dict:
+            fix_dtype(config_dict["text_config"])
+            hf_config.text_config = type("TextConfig", (), config_dict["text_config"])()
+        if "vision_config" in config_dict:
+            fix_dtype(config_dict["vision_config"])
+            hf_config.vision_config = type("VisionConfig", (), config_dict["vision_config"])()
+        return AutoBridge.from_config(hf_config)
+
+
 def add_convertion_args(parser):
     """Add conversion arguments to the parser"""
     parser.add_argument("--hf-checkpoint", type=str, required=True, help="HuggingFace model path")
